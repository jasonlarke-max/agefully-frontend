---
import BaseLayout from '../layouts/BaseLayout.astro';

const WP_API = 'https://public-api.wordpress.com/wp/v2/sites/250024892';

const PILLARS = [
  {
    name: 'Health & Comfort',
    slug: 'health-and-comfort',
    tagline: 'Practical steps that make life easier and more comfortable.',
    num: '01',
    image: 'https://agefully.co.uk/wp-content/uploads/2025/12/Gemini_Generated_Image_wpd6prwpd6prwpd6.png',
  },
  {
    name: 'Money & Lifestyle',
    slug: 'money-and-lifestyle',
    tagline: 'Straightforward explanations, smarter financial choices.',
    num: '02',
    image: 'https://agefully.co.uk/wp-content/uploads/2025/11/Money-and-LIfestyle-.jpg',
  },
  {
    name: 'Community & Purpose',
    slug: 'community-and-purpose',
    tagline: 'Connection, contribution, and staying meaningfully involved.',
    num: '03',
    image: 'https://agefully.co.uk/wp-content/uploads/2025/12/community-people.jpg',
  },
  {
    name: 'Home & Design',
    slug: 'home-and-design',
    tagline: 'Guides to make your home simple, calm, and right for you.',
    num: '04',
    image: 'https://agefully.co.uk/wp-content/uploads/2025/12/Gemini_Generated_Image_oe8pg2oe8pg2oe8p-1-e1765548316862.png',
  },
  {
    name: 'Style & Wellbeing',
    slug: 'style-and-wellbeing',
    tagline: 'A modern approach to living well and expressing personal style.',
    num: '05',
    image: 'https://agefully.co.uk/wp-content/uploads/2025/12/Gemini_Generated_Image_g4z433g4z433g4z4.png',
  },
];

let categories = [];
try {
  const res = await fetch(`${WP_API}/categories?per_page=50&_fields=id,name,slug`);
  if (res.ok) categories = await res.json();
} catch (e) {}

let featured: any = null;
try {
  const res = await fetch(`${WP_API}/posts/1301?_embed=1`);
  if (res.ok) featured = await res.json();
} catch (e) {}

function decodeHTML(str: string): string {
  return str
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'");
}

function getPillarName(post: any) {
  if (!post.categories?.length || !categories.length) return null;
  const cat = categories.find((c: any) => post.categories.includes(c.id));
  return cat ? decodeHTML(cat.name) : null;
}

function getFeaturedImage(post: any) {
  try {
    return post._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? null;
  } catch { return null; }
}
---

<BaseLayout title="Clarity for Later Life">

  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__eyebrow">For adults over 60</p>
      <h1 class="hero__heading">Clarity for Later Life.</h1>
      <p class="hero__sub">Practical, independent guidance on the decisions that matter most, sourced honestly, delivered clearly, free from noise.</p>
    </div>
  </section>

  <!-- Pillars -->
  <section class="pillars">
    <div class="container">
      <p class="section-label">Five areas of focus</p>
      <div class="pillars__grid">
        {PILLARS.map(p => (
          <a
            href={`/pillar/${p.slug}`}
            class="pillar-card"
            style={`--card-img: url('${p.image}')`}
          >
            <span class="pillar-card__num">{p.num}</span>
            <span class="pillar-card__name">{p.name}</span>
            <span class="pillar-card__tagline">{p.tagline}</span>
            <span class="pillar-card__arrow" aria-hidden="true">&#8594;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured article -->
  {featured && (() => {
    const pillarName = getPillarName(featured);
    const img = getFeaturedImage(featured);
    const excerpt = featured.excerpt?.rendered?.replace(/<[^>]+>/g, '').trim() ?? '';
    return (
      <section class="featured">
        <div class="container">
          <p class="section-label">Featured read</p>
          <a href={`/${featured.slug}`} class="featured-card">
            {img
              ? <img src={img} alt="" class="featured-card__img" loading="lazy" />
              : <div class="featured-card__img-placeholder" />
            }
            <div class="featured-card__body">
              {pillarName && <span class="featured-card__pillar">{pillarName}</span>}
              <h2 class="featured-card__title" set:html={featured.title.rendered} />
              {excerpt && <p class="featured-card__excerpt">{excerpt.slice(0, 220)}{excerpt.length > 220 ? '…' : ''}</p>}
              <span class="featured-card__cta">Read article &rarr;</span>
            </div>
          </a>
        </div>
      </section>
    );
  })()}

  <!-- Editorial promise strip -->
  <section class="editorial-strip">
    <div class="prose-container">
      <h2 class="editorial-strip__heading">Guidance you can trust.</h2>
      <p class="editorial-strip__body">Most information aimed at adults over 60 is generic, commercially shaped, or confident without being reliable. Agefully attributes claims to named UK institutions, states evaluation criteria before product names, and says plainly when the honest answer is to speak to a professional.</p>
      <a href="/about" class="editorial-strip__link">About Agefully &rarr;</a>
    </div>
  </section>

  <!-- Email signup -->
  <section class="email-signup">
    <div class="prose-container">
      <p class="section-label">Stay informed</p>
      <h2 class="email-signup__heading">Practical guidance, delivered clearly.</h2>
      <p class="email-signup__sub">One email when something is worth your time. No filler.</p>
      <div class="klaviyo-form-Ub73z8"></div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="trust-strip">
    <div class="prose-container">
      <p class="trust-strip__text">Agefully earns a small commission when readers buy through links in its articles. A committed proportion will support Age UK Norwich. This does not affect recommendations or the price you pay. <a href="/the-agefully-model">How The Agefully Model works &rarr;</a></p>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ─────────────────────────────── */
.hero {
  min-height: 65vh;
  display: flex;
  align-items: center;
  background:
    linear-gradient(rgba(24,77,87,0.82), rgba(24,77,87,0.82)),
    url('https://agefully.co.uk/wp-content/uploads/2025/12/u1259358386_a_full-bleed_cinematic_lifestyle_photograph_of_a__aa1fe957-bb00-45ec-b842-b067f0a58b71_3-1.png') center / cover no-repeat;
  padding: 5rem 1.5rem;
}

.hero__inner {
  max-width: 720px;
  margin: 0 auto;
  width: 100%;
}

.hero__eyebrow {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(249,245,242,0.55);
  margin-bottom: 1.25rem;
}

.hero__heading {
  font-family: var(--font-head);
  font-size: clamp(3.25rem, 8vw, 5.5rem);
  font-weight: 300;
  color: var(--cream);
  line-height: 1.05;
  margin-bottom: 1.5rem;
  letter-spacing: -0.01em;
}

.hero__sub {
  font-family: var(--font-body);
  font-size: 1.1875rem;
  font-weight: 300;
  color: rgba(249,245,242,0.75);
  line-height: 1.65;
  max-width: 520px;
}

/* ── Section label ────────────────────── */
.section-label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-bottom: 1.5rem;
}

/* ── Pillars ──────────────────────────── */
.pillars {
  padding: 4rem 0 3.5rem;
  border-bottom: 1px solid var(--teal-border);
}

.pillars__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1px;
  background: var(--teal-border);
  border: 1px solid var(--teal-border);
  border-radius: 4px;
  overflow: hidden;
}

.pillar-card {
  /* Background image with teal overlay via CSS custom property */
  background-image:
    linear-gradient(rgba(24,77,87,0.72), rgba(24,77,87,0.72)),
    var(--card-img, linear-gradient(var(--teal), var(--teal)));
  background-size: cover;
  background-position: center;
  padding: 1.5rem 1.25rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  text-decoration: none;
  min-height: 240px;
  transition: background-image 0.2s ease;
}

.pillar-card:hover {
  /* Lift overlay on hover to reveal more of the image */
  background-image:
    linear-gradient(rgba(24,77,87,0.55), rgba(24,77,87,0.55)),
    var(--card-img, linear-gradient(var(--teal), var(--teal)));
  text-decoration: none;
}

.pillar-card__num {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: rgba(249,245,242,0.45);
}

.pillar-card__name {
  font-family: var(--font-head);
  font-size: 1rem;
  font-weight: 400;
  color: var(--cream);
  line-height: 1.3;
}

.pillar-card__tagline {
  font-size: 0.8125rem;
  color: rgba(249,245,242,0.72);
  line-height: 1.55;
  flex: 1;
}

.pillar-card__arrow {
  font-size: 1rem;
  color: var(--cream);
  margin-top: 0.5rem;
  opacity: 0;
  transition: opacity 0.2s;
}

.pillar-card:hover .pillar-card__arrow {
  opacity: 1;
}

/* ── Featured article ─────────────────── */
.featured {
  padding: 4rem 0;
  border-bottom: 1px solid var(--teal-border);
}

.featured-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3.5rem;
  align-items: center;
  text-decoration: none;
  color: inherit;
}

.featured-card:hover { text-decoration: none; }

.featured-card__img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  border-radius: 4px;
}

.featured-card__img-placeholder {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: var(--teal-muted);
  border-radius: 4px;
}

.featured-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}

.featured-card__pillar {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--teal);
}

.featured-card__title {
  font-family: var(--font-head);
  font-size: clamp(1.625rem, 3vw, 2.25rem);
  font-weight: 300;
  color: var(--ink);
  line-height: 1.2;
  margin: 0;
}

.featured-card__excerpt {
  font-size: 1rem;
  color: var(--ink-muted);
  line-height: 1.65;
  margin: 0;
}

.featured-card__cta {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--teal);
}

.featured-card:hover .featured-card__cta {
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* ── Editorial promise strip ──────────── */
.editorial-strip {
  background: var(--teal);
  padding: 5rem 1.5rem;
}

.editorial-strip__heading {
  font-family: var(--font-head);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 300;
  color: var(--cream);
  line-height: 1.15;
  margin-bottom: 1.25rem;
}

.editorial-strip__body {
  font-size: 1.0625rem;
  color: rgba(249,245,242,0.75);
  line-height: 1.7;
  margin-bottom: 1.75rem;
  max-width: 580px;
}

.editorial-strip__link {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--cream);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(249,245,242,0.4);
  transition: text-decoration-color 0.15s;
}

.editorial-strip__link:hover {
  text-decoration-color: var(--cream);
}

/* ── Email signup ─────────────────────── */
.email-signup {
  padding: 5rem 1.5rem 4rem;
  border-bottom: 1px solid var(--teal-border);
}

.email-signup__heading {
  font-family: var(--font-head);
  font-size: clamp(1.5rem, 3.5vw, 2.25rem);
  font-weight: 300;
  color: var(--ink);
  line-height: 1.2;
  margin-bottom: 0.5rem;
}

.email-signup__sub {
  font-size: 1rem;
  color: var(--ink-muted);
  margin-bottom: 2rem;
  line-height: 1.5;
}

/* ── Trust strip ──────────────────────── */
.trust-strip {
  padding: 2rem 0;
}

.trust-strip__text {
  font-size: 0.8125rem;
  color: var(--ink-faint);
  line-height: 1.65;
}

.trust-strip__text a {
  color: var(--teal);
}

/* ── Responsive ───────────────────────── */
@media (max-width: 1024px) {
  .pillars__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 900px) {
  .featured-card {
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
}

@media (max-width: 640px) {
  .pillars__grid {
    grid-template-columns: 1fr 1fr;
  }
  .hero {
    min-height: 55vh;
    padding: 4rem 1.5rem 3.5rem;
  }
}
</style>
