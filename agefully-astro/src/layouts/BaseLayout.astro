---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Practical, independent guidance for adults over 60. Clarity for Later Life.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const pillars = [
  { label: 'Health & Comfort', href: '/pillar/health-and-comfort' },
  { label: 'Money & Lifestyle', href: '/pillar/money-and-lifestyle' },
  { label: 'Community & Purpose', href: '/pillar/community-and-purpose' },
  { label: 'Home & Design', href: '/pillar/home-and-design' },
  { label: 'Style & Wellbeing', href: '/pillar/style-and-wellbeing' },
];
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Agefully`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title} | Agefully</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Klaviyo -->
    <script async type="text/javascript" src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Yjpm8D"></script>

    <!-- Klaviyo popup: trigger at 60% scroll, not on load -->
    <script is:inline>
      (function () {
        var triggered = false;
        function onScroll() {
          if (triggered) return;
          var scrollable = document.documentElement.scrollHeight - window.innerHeight;
          if (scrollable > 0 && window.scrollY / scrollable >= 0.6) {
            triggered = true;
            window.removeEventListener('scroll', onScroll);
            window._klOnsite = window._klOnsite || [];
            window._klOnsite.push(['openForm', 'Ub73z8']);
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </head>
  <body>
    <header>
      <nav class="site-nav">
        <div class="site-nav__inner">
          <a href="/" class="site-nav__logo">Agefully</a>
          <ul class="site-nav__links">
            {pillars.map(p => (
              <li><a href={p.href}>{p.label}</a></li>
            ))}
            <li><a href="/about">About</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <div class="site-footer__brand">Agefully</div>
          <p class="site-footer__tagline">Clarity for Later Life.<br />Practical guidance for adults over 60.</p>
        </div>

        <div>
          <div class="site-footer__heading">Pillars</div>
          <ul class="site-footer__links">
            {pillars.map(p => (
              <li><a href={p.href}>{p.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <div class="site-footer__heading">Agefully</div>
          <ul class="site-footer__links">
            <li><a href="/about">About</a></li>
            <li><a href="/how-agefully-works">How It Works</a></li>
            <li><a href="/the-agefully-model">The Agefully Model</a></li>
            <li><a href="/editorial-promise">Editorial Promise</a></li>
            <li><a href="/disclosure">Disclosure</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
          </ul>
        </div>
      </div>

      <div class="site-footer__bottom">
        <span class="site-footer__legal">
          &copy; {new Date().getFullYear()} Agefully. A Larkehouse Ltd publication.
        </span>
        <span class="site-footer__legal">
          A committed proportion of affiliate income supports Age UK Norwich.
        </span>
      </div>
    </footer>
  </body>
</html>
