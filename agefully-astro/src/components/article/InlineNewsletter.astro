---
// Injected programmatically after 3rd H2 in articles >1200 words.
// Renders the Klaviyo form embed.
---

<aside class="af-newsletter">
  <div class="af-newsletter__inner">
    <div>
      <p class="af-newsletter__label">Agefully newsletter</p>
      <p class="af-newsletter__pitch">One email a week. Practical guides. No filler.</p>
    </div>
    <div class="klaviyo-form-RQPLie"></div>
  </div>
</aside>

<style>
.af-newsletter {
  max-width: 820px;
  margin: 3.5rem auto;
  padding: 2rem;
  background: var(--agefully-cream);
  border-top: 2px solid var(--agefully-teal);
}
.af-newsletter__inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 2rem;
  align-items: center;
}
@media (max-width: 640px) {
  .af-newsletter__inner { grid-template-columns: 1fr; }
}
.af-newsletter__label {
  font: var(--type-meta);
  color: var(--agefully-teal);
  margin: 0 0 0.5rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.af-newsletter__pitch {
  font-family: "Fraunces", serif;
  font-size: 22px;
  line-height: 1.3;
  color: var(--agefully-ink);
  margin: 0;
  padding: 0;
  max-width: none;
}
</style>
