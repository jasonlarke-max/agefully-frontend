---
export interface Props {
  quote: string;
  attribution?: string | null;
}
const { quote, attribution } = Astro.props;
---

<aside class="af-pullquote">
  <div class="af-pullquote__mark" aria-hidden="true">&ldquo;</div>
  <p class="af-pullquote__text">{quote}</p>
  {attribution && <cite class="af-pullquote__cite">{attribution}</cite>}
</aside>

<style>
.af-pullquote {
  max-width: 820px;
  margin: 3.5rem auto;
  padding: 1rem 24px;
  text-align: center;
  position: relative;
}
.af-pullquote__mark {
  font-family: "Fraunces", serif;
  font-size: 64px;
  line-height: 1;
  color: var(--agefully-teal);
  margin-bottom: -20px;
  font-style: italic;
}
.af-pullquote__text {
  font-family: "Fraunces", serif;
  font-size: clamp(26px, 3vw, 34px);
  font-style: italic;
  font-weight: 400;
  line-height: 1.3;
  color: var(--agefully-teal);
  margin: 0;
  padding: 0;
  max-width: none;
}
.af-pullquote__cite {
  display: block;
  font: var(--type-meta);
  color: var(--agefully-graphite);
  margin-top: 1rem;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
</style>
