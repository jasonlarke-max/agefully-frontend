---
export interface Props {
  category: string;
  categorySlug: string;
  publishedDate: string;
  updatedDate?: string | null;
}

const { category, categorySlug, publishedDate, updatedDate } = Astro.props;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<footer class="af-footer">
  <p class="af-footer__back">
    More from <a href={`/pillar/${categorySlug}/`}>{category}</a>
  </p>
  <div class="af-footer__meta">
    <span>Published {formatDate(publishedDate)}</span>
    {updatedDate && <span>Updated {formatDate(updatedDate)}</span>}
  </div>
</footer>

<style>
.af-footer {
  max-width: 680px;
  margin: 3rem auto 4rem;
  padding: 2rem 24px 0;
  border-top: 1px solid var(--agefully-rule);
  text-align: center;
}
.af-footer__back {
  font-family: "Fraunces", serif;
  font-size: 20px;
  margin: 0 0 1rem;
  padding: 0;
  max-width: none;
}
.af-footer__back a {
  color: var(--agefully-teal);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 4px;
}
.af-footer__meta {
  font: var(--type-meta);
  color: var(--agefully-muted);
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
</style>
