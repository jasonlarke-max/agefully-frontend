---
export interface Props {
  category: string;
  categorySlug: string;
  publishedDate: string;
  updatedDate?: string | null;
  readTimeMinutes: number;
  title: string;
  dek?: string | null;
  reviewer?: { name: string; credential: string } | null;
}

const {
  category,
  categorySlug,
  publishedDate,
  updatedDate,
  readTimeMinutes,
  title,
  dek,
  reviewer,
} = Astro.props;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<header class="af-header">
  <a href={`/pillar/${categorySlug}/`} class="af-header__category">{category}</a>
  <div class="af-header__meta">
    <time datetime={publishedDate}>{formatDate(publishedDate)}</time>
    <span class="af-header__dot">·</span>
    <span>{readTimeMinutes} min read</span>
    {updatedDate && (
      <>
        <span class="af-header__dot">·</span>
        <span>Updated {formatDate(updatedDate)}</span>
      </>
    )}
  </div>
  <h1 class="af-header__title" set:html={title} />
  {dek && <p class="af-header__dek">{dek}</p>}
  {reviewer && (
    <p class="af-header__reviewer">
      Reviewed by <strong>{reviewer.name}</strong>, {reviewer.credential}
    </p>
  )}
</header>

<style>
.af-header {
  max-width: 820px;
  margin: 0 auto 3rem;
  padding: 3rem 24px 0;
  text-align: left;
}
.af-header__category {
  font: var(--type-meta);
  color: var(--agefully-teal);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: inline-block;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--agefully-teal);
  margin-bottom: 1.5rem;
}
.af-header__meta {
  font: var(--type-meta);
  color: var(--agefully-graphite);
  margin-bottom: 1.5rem;
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  align-items: center;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.af-header__dot {
  color: var(--agefully-muted);
}
.af-header__title {
  font-family: "Fraunces", serif;
  font-size: clamp(42px, 5vw, 64px);
  font-weight: 450;
  line-height: 1.08;
  letter-spacing: -0.01em;
  color: var(--agefully-ink);
  margin: 0 0 1.5rem;
}
.af-header__dek {
  font-family: "Source Serif 4", serif;
  font-size: 22px;
  line-height: 1.45;
  color: var(--agefully-graphite);
  max-width: 620px;
  margin: 0 0 1.5rem;
}
.af-header__reviewer {
  font-family: "Source Serif 4", serif;
  font-size: 14px;
  color: var(--agefully-graphite);
  margin: 0;
  padding-top: 1rem;
  border-top: 1px solid var(--agefully-rule);
}
</style>
